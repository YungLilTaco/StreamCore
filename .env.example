## Core
NEXT_PUBLIC_APP_NAME="StreamCore"

## Auth.js (NextAuth v5)
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# Your production URL (Vercel sets this automatically, but it's good to document)
NEXTAUTH_URL="https://your-app.vercel.app"

## Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

## Twitch OAuth
TWITCH_CLIENT_ID="replace-me"
TWITCH_CLIENT_SECRET="replace-me"

## Spotify OAuth
SPOTIFY_CLIENT_ID="replace-me"
SPOTIFY_CLIENT_SECRET="replace-me"

